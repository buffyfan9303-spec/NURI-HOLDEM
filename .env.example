# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase 프로젝트 대시보드 → Project Settings → API 에서 확인
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Kakao Maps ───────────────────────────────────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key_here

# ── Storage 버킷 이름 (Supabase Storage) ────────────────────────────────────
# supabase/schema.sql 실행 후 자동 생성됨
VITE_STORAGE_BUCKET_POSTERS=posters
VITE_STORAGE_BUCKET_LISTINGS=listings
VITE_STORAGE_BUCKET_COMMUNITY=community_images

# ── 본인인증 PortOne V2 (IdentityVerificationButton) ─────────────────────────
# https://admin.portone.io → 결제연동 → 식별코드/채널. 미설정 시 본인인증 버튼 비활성.
VITE_PORTONE_STORE_ID=store-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Sentry (에러 모니터링, 선택) ──────────────────────────────────────────────
# 미설정 시 Sentry 비활성(앱 정상 동작). https://sentry.io → 프로젝트 → DSN
VITE_SENTRY_DSN=

# ── Edge Function 시크릿(클라이언트 아님 — Supabase 대시보드 → Edge Functions → Secrets) ──
# PORTONE_V2_API_SECRET   본인인증 교차검증(verify-identity)
# VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY  웹푸시(send-push). 공개키는 src/api/push.ts 와 반드시 동일해야 함
# RESEND_API_KEY / SANCTION_FROM        제재 안내 메일(notify-sanction). 미설정 시 메일 미발송(상태변경은 성공)
# GEMINI_API_KEY                        순위 인증 이미지 검사(gemini). 미설정 시 규칙 폴백
