# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase 프로젝트 대시보드 → Project Settings → API 에서 확인
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Kakao Maps ───────────────────────────────────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key_here

# ── Storage 버킷 이름 (Supabase Storage) ────────────────────────────────────
# supabase/schema.sql 실행 후 자동 생성됨
VITE_STORAGE_BUCKET_POSTERS=posters
VITE_STORAGE_BUCKET_LISTINGS=listings
